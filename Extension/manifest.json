{
  "manifest_version": 3,
  "name": "Raven AI — Save to Knowledge Vault",
  "version": "1.1.0",
  "description": "Save any page or link to your Raven AI knowledge vault with one click.",
  "permissions": ["activeTab", "storage", "contextMenus"],
  "host_permissions": [
    "http://localhost:5000/*",
    "http://localhost:5173/*",
    "https://*/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Raven AI",
    "default_icon": {
      "16":  "icons/icon16.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost:5173/*",
        "https://your-raven-app.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16":  "icons/icon16.png"
  }
}
